# IKARIS Backend — Environment Variables
# Copy this file to .env and fill in your values
# cp .env.example .env

# ── LLM (NVIDIA NeMo / OpenAI-compatible) ────────────────────────────────────
# Get a free NVIDIA API key at: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_api_key_here

# OpenAI-compatible base URL (NVIDIA NeMo endpoint)
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Embeddings ────────────────────────────────────────────────────────────────
# HuggingFace embeddings run locally — no API key needed.
# Model: sentence-transformers/all-MiniLM-L6-v2 (downloaded automatically)

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_PORT=5000

# ── Data ──────────────────────────────────────────────────────────────────────
# Path to CBRE CSV data (relative to backend/)
DATA_DIR=./data/cbre_data
